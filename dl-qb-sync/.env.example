# Dentalink
DENTALINK_BASE_URL=https://api.dentalink.healthatom.com/api/v1
DENTALINK_TOKEN=

# QuickBooks Online (Intuit Developer app)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=production
QBO_REDIRECT_URI=http://localhost:8765/api/qbo/callback 
QBO_REALM_ID=
# Se completan tras el primer login OAuth (ver server/integrations/quickbooks.js)
QBO_REFRESH_TOKEN=

# Convencion de sufijo usada para matchear pacientes ya existentes en QuickBooks
# Ejemplo de nombre en QuickBooks: "Juan Perez - DL12345"
DL_CUSTOMER_SUFFIX_PREFIX=DL

PORT=8765

# --- Supabase (base de datos + login) ---
# Crea las tablas corriendo sql/schema.sql en el SQL Editor de tu proyecto Supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Secreta, solo se usa en el backend. Nunca exponer al frontend ni commitear.
SUPABASE_SERVICE_ROLE_KEY=

# Expuestas al frontend (Vite solo expone variables con prefijo VITE_)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
